		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.access_token) {",
									"  pm.collectionVariables.set('adminToken', res.access_token);",
									"  console.log('Admin token saved.');",
									"} else {",
									"  console.error('No access_token in response:', JSON.stringify(res));",
									"}",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has access_token', () => pm.expect(res).to.have.property('access_token'));",
									"pm.test('User role is ADMIN', () => pm.expect(res.user.role).to.eql('ADMIN'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@pharmoris.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
